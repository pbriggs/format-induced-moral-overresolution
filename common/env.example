# Copy the variables you need into your shell, deployment secret store, or a
# local .env loader. The library itself intentionally does not read .env files.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.5

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4.3

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3.7-max

# Optional only when model-name inference is insufficient:
# MODEL_PROVIDER_MAP=custom-model=openai,qwen/qwen3.7-max=openrouter

# Original-project aliases are also supported:
# LLAMA_API_KEY=
# LLAMA_BASE_URL=https://openrouter.ai/api/v1
# LLAMA_MODEL=qwen/qwen3.7-max

# Google support remains in the reusable adapter even though Gemini was
# replaced by Grok in the final five-model run.
GOOGLE_API_KEY=
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODEL=
