# Milestone execution
STUDY_MODEL_IDS=
RUN_ID=production_milestones_cumulative_v1
OUT_DIR=runs
SUBSET_SEED=20260615
SCRUPLES_SPLITS=train,dev,test
SHARD_COUNT=20

# Optional smoke mode; do not use for real provider collection.
MOCK_PROVIDER=0

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=

# Google
GOOGLE_API_KEY=
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODEL=

# OpenRouter/Together-compatible open-weight route.
# Historical LLAMA_* names are retained for compatibility; Qwen, DeepSeek,
# Mistral, or comparable stronger OpenRouter-hosted models are acceptable.
LLAMA_API_KEY=
LLAMA_BASE_URL=https://openrouter.ai/api/v1
LLAMA_MODEL=

# Optional explicit routing, e.g.
# STUDY_MODEL_PROVIDER_MAP=model-a=openai,model-b=anthropic,model-c=google,model-d=llama,model-e=llama
STUDY_MODEL_PROVIDER_MAP=
